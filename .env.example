# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Catalog
CATALOG_PATH=data/shl_product_catalog.json

# Retrieval 
RETRIEVAL_MODE=keyword
LAZY_INIT=true
USE_RERANKER=false

# Embedding retrieval (local dev — pip install -r requirements-embeddings.txt)
CHROMA_PATH=data/chroma
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_FALLBACK_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# API
MAX_RECOMMENDATIONS=10
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,https://your-app.netlify.app

# Frontend (Netlify build)
VITE_API_URL=http://localhost:8000
